# ================================
# قاعدة البيانات والملفات المحلية
# ================================
# تجاهل ملفات قاعدة البيانات (لا نرفعها لـ GitHub)
*.db
*.db.*
*.log

# تجاهل مجلد البيانات المحلي (يُنشأ تلقائياً على Render)
data/
uploads/
temp/

# ================================
# بيئة التطوير والمكتبات
# ================================
node_modules/
.npm/
yarn-error.log

# ================================
# ملفات البيئة والمتغيرات السرية
# ================================
.env
.env.local
.env.*.local
*.pem
*.key

# ================================
# ملفات نظام التشغيل والمحرر
# ================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ================================
# ملفات Electron والبناء
# ================================
dist/
build/
out/
*.exe
*.msi
*.dmg
*.AppImage
*.snap
*.deb
*.rpm

# ================================
# سجلات وأخطاء Node.js
# ================================
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ================================
# ملفات IDE والمحررات
# ================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ================================
# ملفات النسخ الاحتياطي المؤقتة
# ================================
backup/
backups/
*.bak
*.tmp
*.temp